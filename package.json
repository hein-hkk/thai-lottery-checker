{
  "name": "thai-lottery-checker",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build:packages": "pnpm -r --filter @thai-lottery-checker/types --filter @thai-lottery-checker/schemas --filter @thai-lottery-checker/domain --filter @thai-lottery-checker/i18n --filter @thai-lottery-checker/utils build",
    "dev": "pnpm build:packages && dotenv -e .env -- pnpm --parallel --filter @thai-lottery-checker/web --filter @thai-lottery-checker/api dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @thai-lottery-checker/api db:generate",
    "db:migrate:dev": "dotenv -e .env -- pnpm --filter @thai-lottery-checker/api db:migrate:dev",
    "db:migrate:deploy": "dotenv -e .env -- pnpm --filter @thai-lottery-checker/api db:migrate:deploy",
    "db:studio": "dotenv -e .env -- pnpm --filter @thai-lottery-checker/api db:studio",
    "db:seed": "dotenv -e .env -- pnpm --filter @thai-lottery-checker/api db:seed",
    "test": "pnpm build:packages && pnpm exec dotenv -e .env -- pnpm --filter @thai-lottery-checker/api exec node --import tsx --test tests/results-api.test.ts ../../packages/domain/tests/results.test.ts ../../packages/schemas/tests/results.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@next/eslint-plugin-next": "^16.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.23.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0"
  }
}
