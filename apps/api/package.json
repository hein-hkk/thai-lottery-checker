{
  "name": "@thai-lottery-checker/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "dotenv -e ../../.env -- node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/results-api.test.ts",
    "test:security": "node --import tsx --test tests/security-api.test.ts",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:admin": "tsx prisma/seed-admin-only.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.888.0",
    "@aws-sdk/s3-presigned-post": "^3.888.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "@thai-lottery-checker/domain": "workspace:*",
    "@thai-lottery-checker/schemas": "workspace:*",
    "@thai-lottery-checker/types": "workspace:*",
    "@thai-lottery-checker/utils": "workspace:*",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "pg": "^8.16.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "prisma": "^7.0.0",
    "tsx": "^4.19.3"
  }
}
