generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Locale {
  en
  th
  my
}

enum PublishStatus {
  draft
  published
}

enum PrizeType {
  FIRST_PRIZE
  NEAR_FIRST_PRIZE
  SECOND_PRIZE
  THIRD_PRIZE
  FOURTH_PRIZE
  FIFTH_PRIZE
  FRONT_THREE
  LAST_THREE
  LAST_TWO
}

enum AdminRole {
  super_admin
  editor
}

enum AdminPermission {
  manage_results
  manage_blogs
}

model SystemHeartbeat {
  id        Int      @id @default(1)
  label     String   @default("foundation")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_heartbeat")
}

model Admin {
  id                   String                      @id @default(uuid()) @db.Uuid
  email                String                      @unique
  name                 String?
  passwordHash         String                      @map("password_hash")
  role                 AdminRole                   @default(editor)
  isActive             Boolean                     @default(true) @map("is_active")
  passwordUpdatedAt    DateTime?                   @map("password_updated_at")
  deactivatedAt        DateTime?                   @map("deactivated_at")
  lastLoginAt          DateTime?                   @map("last_login_at")
  invitedByAdminId     String?                     @db.Uuid @map("invited_by_admin_id")
  createdAt            DateTime                    @default(now()) @map("created_at")
  updatedAt            DateTime                    @updatedAt @map("updated_at")
  invitedByAdmin       Admin?                      @relation("admin_inviter", fields: [invitedByAdminId], references: [id], onDelete: SetNull)
  invitedAdmins        Admin[]                     @relation("admin_inviter")
  permissions          AdminPermissionGrant[]
  invitationsSent      AdminInvitation[]           @relation("admin_invitation_sender")
  passwordResets       AdminPasswordReset[]
  auditLogs            AdminAuditLog[]
  createdDraws         LotteryDraw[]               @relation("draw_created_by_admin")
  updatedDraws         LotteryDraw[]               @relation("draw_updated_by_admin")
  createdBlogPosts     BlogPost[]                  @relation("blog_created_by_admin")
  updatedBlogPosts     BlogPost[]                  @relation("blog_updated_by_admin")
  releasedResultGroups LotteryResultGroupRelease[] @relation("result_group_release_admin")

  @@map("admins")
}

model AdminPermissionGrant {
  id         String          @id @default(uuid()) @db.Uuid
  adminId    String          @db.Uuid @map("admin_id")
  permission AdminPermission
  createdAt  DateTime        @default(now()) @map("created_at")
  admin      Admin           @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([adminId, permission], map: "admin_permissions_admin_id_permission_key")
  @@map("admin_permissions")
}

model AdminInvitation {
  id               String    @id @default(uuid()) @db.Uuid
  email            String
  role             AdminRole
  tokenHash        String    @map("token_hash")
  permissionsJson  Json?     @map("permissions_json")
  expiresAt        DateTime  @map("expires_at")
  acceptedAt       DateTime? @map("accepted_at")
  revokedAt        DateTime? @map("revoked_at")
  invitedByAdminId String    @db.Uuid @map("invited_by_admin_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  invitedByAdmin   Admin     @relation("admin_invitation_sender", fields: [invitedByAdminId], references: [id], onDelete: Restrict)

  @@map("admin_invitations")
}

model AdminPasswordReset {
  id         String    @id @default(uuid()) @db.Uuid
  adminId    String    @db.Uuid @map("admin_id")
  tokenHash  String    @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  usedAt     DateTime? @map("used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  admin      Admin     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_password_resets")
}

model AdminAuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  adminId    String   @db.Uuid @map("admin_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @db.Uuid @map("entity_id")
  beforeData Json?    @map("before_data")
  afterData  Json?    @map("after_data")
  createdAt  DateTime @default(now()) @map("created_at")
  admin      Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_audit_logs")
}

model LotteryDraw {
  id               String         @id @default(uuid()) @db.Uuid
  drawDate         DateTime       @unique @db.Date @map("draw_date")
  drawCode         String?        @map("draw_code")
  status           PublishStatus  @default(draft)
  publishedAt      DateTime?      @map("published_at")
  createdByAdminId String         @db.Uuid @map("created_by_admin_id")
  updatedByAdminId String         @db.Uuid @map("updated_by_admin_id")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  createdByAdmin   Admin          @relation("draw_created_by_admin", fields: [createdByAdminId], references: [id])
  updatedByAdmin   Admin          @relation("draw_updated_by_admin", fields: [updatedByAdminId], references: [id])
  results          LotteryResult[]
  groupReleases    LotteryResultGroupRelease[]

  @@index([status])
  @@index([publishedAt], map: "lottery_draws_published_at_idx")
  @@map("lottery_draws")
}

model LotteryResult {
  id         String      @id @default(uuid()) @db.Uuid
  drawId     String      @db.Uuid @map("draw_id")
  prizeType  PrizeType   @map("prize_type")
  prizeIndex Int         @default(0) @map("prize_index")
  number     String
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  draw       LotteryDraw @relation(fields: [drawId], references: [id], onDelete: Cascade)

  @@index([drawId], map: "lottery_results_draw_id_idx")
  @@index([drawId, prizeType], map: "lottery_results_draw_id_prize_type_idx")
  @@unique([drawId, prizeType, prizeIndex], map: "lottery_results_draw_id_prize_type_prize_index_key")
  @@map("lottery_results")
}

model LotteryResultGroupRelease {
  id                String      @id @default(uuid()) @db.Uuid
  drawId            String      @db.Uuid @map("draw_id")
  prizeType         PrizeType   @map("prize_type")
  isReleased        Boolean     @default(false) @map("is_released")
  releasedAt        DateTime?   @map("released_at")
  releasedByAdminId String?     @db.Uuid @map("released_by_admin_id")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")
  draw              LotteryDraw @relation(fields: [drawId], references: [id], onDelete: Cascade)
  releasedByAdmin   Admin?      @relation("result_group_release_admin", fields: [releasedByAdminId], references: [id])

  @@index([drawId], map: "lottery_result_group_releases_draw_id_idx")
  @@index([drawId, isReleased], map: "lottery_result_group_releases_draw_id_is_released_idx")
  @@unique([drawId, prizeType], map: "lottery_result_group_releases_draw_id_prize_type_key")
  @@map("lottery_result_group_releases")
}

model BlogPost {
  id               String                @id @default(uuid()) @db.Uuid
  slug             String                @unique
  bannerImageUrl   String?               @map("banner_image_url")
  status           PublishStatus         @default(draft)
  publishedAt      DateTime?             @map("published_at")
  createdByAdminId String                @db.Uuid @map("created_by_admin_id")
  updatedByAdminId String                @db.Uuid @map("updated_by_admin_id")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")
  createdByAdmin   Admin                 @relation("blog_created_by_admin", fields: [createdByAdminId], references: [id])
  updatedByAdmin   Admin                 @relation("blog_updated_by_admin", fields: [updatedByAdminId], references: [id])
  translations     BlogPostTranslation[]

  @@index([status], map: "blog_posts_status_idx")
  @@index([publishedAt], map: "blog_posts_published_at_idx")
  @@map("blog_posts")
}

model BlogPostTranslation {
  id             String   @id @default(uuid()) @db.Uuid
  blogPostId     String   @db.Uuid @map("blog_post_id")
  locale         Locale
  title          String
  body           Json
  excerpt        String?
  seoTitle       String?  @map("seo_title")
  seoDescription String?  @map("seo_description")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  blogPost       BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)

  @@unique([blogPostId, locale], map: "blog_post_translations_blog_post_id_locale_key")
  @@map("blog_post_translations")
}
